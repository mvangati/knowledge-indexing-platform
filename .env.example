# Database
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge.db

# Auth — comma-separated tenantId:apiKey pairs
# In production, use AWS Secrets Manager or Vault
TENANT_KEYS=tenant1:key-tenant1-secret,tenant2:key-tenant2-secret

# API header name that carries the tenant API key
API_KEY_HEADER=X-API-Key

# Logging
LOG_LEVEL=INFO

# Search limits
SEARCH_DEFAULT_LIMIT=10
SEARCH_MAX_LIMIT=100

# Max document content size in kilobytes
MAX_DOCUMENT_SIZE_KB=5120
